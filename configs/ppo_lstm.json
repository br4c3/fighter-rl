{
  "comment": "Default PPO LSTM gun-bucket curriculum training config.",
  "variant": "ppo_lstm",
  "device": "cuda",
  "num_envs": 4096,
  "horizon": 16,
  "epochs": 4,
  "minibatch": 65536,
  "lr": 0.0001,
  "gamma": 0.99,
  "gae_lambda": 0.95,
  "clip": 0.2,
  "vf_coef": 0.5,
  "entropy_coef": 0.002,
  "grad_clip": 0.5,
  "log_std_min": -5.0,
  "log_std_max": 1.0,
  "action_mean_clip": 10.0,
  "action_mean_l2_coef": 0.0001,
  "min_valid_fraction": 0.05,
  "max_updates_per_stage": 20000,
  "advance_window": 8,
  "advance_patience": 3,
  "checkpoint_interval": 50,
  "log_interval": 1,
  "start_stage": 0,
  "stop_stage": 14,
  "stage_schedule": "gun_bucket_curriculum",
  "resume": null,
  "output": "fast_aip_ppo_runs/bucket_gun_ppo_lstm",
  "seed": 7,
  "target_maneuver": "gun_curriculum",
  "no_domain_randomization": false,
  "no_auto_advance": false
}
