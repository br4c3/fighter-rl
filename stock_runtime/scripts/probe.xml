<?xml version="1.0" encoding="utf-8"?>
<runscript name="DLL equivalence probe">
  <use aircraft="f16" initialize="f16_init"/>
  <run start="0" end="12" dt="0.02">
    <event name="engine running">
      <condition>simulation/sim-time-sec ge 0</condition>
      <set name="fcs/throttle-cmd-norm" value="1.0"/>
      <set name="fcs/aileron-cmd-norm" value="0"/>
      <set name="fcs/elevator-cmd-norm" value="0"/>
      <set name="fcs/rudder-cmd-norm" value="0"/>
    </event>
    <event name="first external throttle command">
      <condition>simulation/sim-time-sec ge 0.02</condition>
      <set name="fcs/throttle-cmd-norm" value="0.65"/>
    </event>
    <event name="roll positive">
      <condition>simulation/sim-time-sec ge 2.04</condition>
      <set name="fcs/aileron-cmd-norm" value="0.45"/>
    </event>
    <event name="roll negative">
      <condition>simulation/sim-time-sec ge 5.039</condition>
      <set name="fcs/aileron-cmd-norm" value="-0.45"/>
    </event>
    <event name="roll neutral">
      <condition>simulation/sim-time-sec ge 8.039</condition>
      <set name="fcs/aileron-cmd-norm" value="0"/>
    </event>
  </run>
</runscript>
